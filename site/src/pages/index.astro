---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import GalleryCard from '../components/GalleryCard.astro';
import PostCard from '../components/PostCard.astro';
import BahaCard from '../components/BahaCard.astro';
import FbCard from '../components/FbCard.astro';
import VideoCard from '../components/VideoCard.astro';
import {
  getGalleries,
  getPosts,
  getBahaPosts,
  getFbPosts,
  getVideos,
  fbMeta,
  type Gallery,
  type Post,
  type BahaPost,
  type FbPost,
  type Video,
} from '../lib/site';

const galleries = await getGalleries();
const posts = await getPosts();
const bahaPosts = await getBahaPosts();
const fbPosts = await getFbPosts();
const videos = getVideos();
const featured = galleries.filter((g) => g.data.featured);

// FB 動態量太大（2000+），牆上只放有「自己貼的圖」的；純文字與站內分享（shared- 預覽圖）
// 仍有頁面、可搜、/group/Facebook/ 全列——分享縮圖是別人的內容，別淹掉自己的牆
const fbWall = fbPosts.filter((f) =>
  (fbMeta(f).images ?? []).some((img) => !img.src.includes('/shared-'))
);

// 封面牆：圖集、文章（Medium＋巴哈）、FB 圖文、影片依日期混排
type WallItem = { date: Date; g?: Gallery; p?: Post; b?: BahaPost; f?: FbPost; v?: Video };
const wall: WallItem[] = [
  ...galleries.map((g) => ({ date: g.data.date, g })),
  ...posts.map((p) => ({ date: p.data.date, p })),
  ...bahaPosts.map((b) => ({ date: b.data.date, b })),
  ...fbWall.map((f) => ({ date: f.data.date, f })),
  ...videos.map((v) => ({ date: new Date(v.published), v })),
].sort((a, b) => b.date.valueOf() - a.date.valueOf());
const nPosts = posts.length + bahaPosts.length;
---

<Layout active="home">
  <Hero
    galleries={galleries.length}
    posts={nPosts}
    fb={fbPosts.length}
    videos={videos.length}
  />

  {
    featured.length > 0 && (
      <>
        <h2 class="sec">熱門作品 <span>popular now</span></h2>
        <div class="grid">
          {featured.map((g) => (
            <GalleryCard g={g} />
          ))}
        </div>
      </>
    )
  }

  <h2 class="sec" id="wall">
    最新上傳
    <span>
      new uploads · {galleries.length} 本圖集 · {nPosts} 篇文章 · {fbPosts.length} 則動態 ·
      {videos.length} 部影片
    </span>
  </h2>
  <div class="grid">
    {
      wall.map((item) =>
        item.g ? (
          <GalleryCard g={item.g} />
        ) : item.p ? (
          <PostCard p={item.p} />
        ) : item.b ? (
          <BahaCard b={item.b} />
        ) : item.f ? (
          <FbCard f={item.f} />
        ) : (
          <VideoCard v={item.v!} />
        )
      )
    }
  </div>
</Layout>
