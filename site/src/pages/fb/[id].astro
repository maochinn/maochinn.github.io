---
import { render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Reader from '../../components/Reader.astro';
import type { Namespace } from '../../data/taxonomy';
import { getFbPosts, getCounts, fbMeta, tagTotal, nsUrl, fmtDate } from '../../lib/site';

export async function getStaticPaths() {
  const posts = await getFbPosts();
  return posts.map((f) => ({ params: { id: f.id }, props: { f } }));
}

const { f } = Astro.props;
const { Content } = await render(f);
const m = fbMeta(f);
const images = m.images ?? [];
const cover = images[0]?.src;

// 分享/影片附件（import-fb.mjs 從備份 meta.attachments 轉進 frontmatter）
const { youtube, video_file, fb_video, link, link_title, link_desc, fb_embed } = f.data;
// 分享 FB 站內貼文：官方 post plugin 會連分享目標一起渲染；點擊才載入（不預載 FB 追蹤）
const embedPost = fb_embed
  ? `https://www.facebook.com/plugins/post.php?href=${encodeURIComponent(f.data.source)}&show_text=true&width=500`
  : null;
let linkHost = '';
try {
  if (link) linkHost = new URL(link).hostname;
} catch { /* 舊貼文偶有怪連結，host 顯示留空就好 */ }
const embed = youtube
  ? `https://www.youtube-nocookie.com/embed/${youtube}`
  : fb_video
    ? `https://www.facebook.com/plugins/video.php?href=${encodeURIComponent(fb_video)}&show_text=false`
    : null;

const counts = await getCounts();
const cnt = (ns: Namespace, name: string) => {
  const c = counts.get(ns)?.get(name);
  return c ? tagTotal(c) : 0;
};
const rows: { label: string; ns: Namespace; names: string[] }[] = [
  { label: '系列', ns: 'parody', names: m.parodies },
  { label: '角色', ns: 'character', names: m.characters },
  { label: '標籤', ns: 'tag', names: m.tags },
  { label: '作者', ns: 'artist', names: m.artists },
  { label: '社團', ns: 'group', names: m.groups },
  { label: '分類', ns: 'category', names: m.categories },
].filter((r) => r.names.length > 0);

const readerPages = images.map((img, i) => ({
  src: img.src,
  caption: img.alt || `第 ${i + 1} 頁`,
}));
---

<Layout title={f.data.title} description={f.data.title}>
  <div class="detail">
    {
      video_file ? (
        <div class="d-cover" style="flex: 1 1 480px; max-width: 720px;">
          <video controls playsinline poster={cover} style="width: 100%; background: #000;" src={video_file} />
        </div>
      ) : embed ? (
        <div class="d-cover" style="flex: 1 1 480px; max-width: 720px;">
          <div style="position: relative; width: 100%; aspect-ratio: 16 / 9; background: #000;">
            <iframe
              src={embed}
              title={f.data.title}
              style="position: absolute; inset: 0; width: 100%; height: 100%; border: 0;"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            />
          </div>
        </div>
      ) : (
        <div class="d-cover">
          <div class="cover">
            {cover ? (
              <img class="coverart" src={cover} alt={f.data.title} />
            ) : (
              <div class="text-cover">
                <span class="tc-title">{f.data.title}</span>
                <i class="tc-mark">STUDIO MAOCHINN · FB</i>
              </div>
            )}
          </div>
        </div>
      )
    }
    <div class="d-info">
      <h1>{f.data.title}</h1>
      <div class="meta" style="margin-top:10px">
        {
          rows.map((r) => (
            <div class="mrow">
              <span>{r.label}</span>
              <div class="chips">
                {r.names.map((name) => (
                  <a class="chip" href={nsUrl(r.ns, name)}>
                    {name} <em>{cnt(r.ns, name)}</em>
                  </a>
                ))}
              </div>
            </div>
          ))
        }
        {
          images.length > 0 && (
            <div class="mrow">
              <span>頁數</span>
              <div class="chips"><span class="chip static">{images.length} pages</span></div>
            </div>
          )
        }
        <div class="mrow">
          <span>發佈於</span>
          <div class="chips"><span class="chip static">{fmtDate(f.data.date)}</span></div>
        </div>
      </div>
      {
        link && (
          <a class="linkcard" href={link} target="_blank" rel="noopener">
            <b>🔗 {link_title ?? link}</b>
            {link_desc && <p>{link_desc}</p>}
            {linkHost && <i>{linkHost}</i>}
          </a>
        )
      }
      <div class="btns">
        {images.length > 0 && <button class="btn pink" id="btn-read">▶ 開始閱讀</button>}
        {youtube && (
          <a class="btn pink" href={`https://www.youtube.com/watch?v=${youtube}`} target="_blank" rel="noopener">
            在 YouTube 開啟 ↗
          </a>
        )}
        <a class="btn grey" href={f.data.source} target="_blank" rel="noopener">在 Facebook 開啟 ↗</a>
      </div>
    </div>
  </div>

  {
    images.length > 0 && (
      <div class="thumbs">
        {images.map((img, i) => (
          <button class="thumb" data-page={i} aria-label={`第 ${i + 1} 頁`}>
            <img src={img.src} alt={img.alt || `第 ${i + 1} 頁`} loading="lazy" />
            <i>{i + 1}</i>
          </button>
        ))}
      </div>
    )
  }

  {
    embedPost && (
      <div id="fb-embed" data-src={embedPost} style="margin-top:26px">
        <button class="btn grey" id="btn-embed">📎 載入 Facebook 分享內容</button>
      </div>
    )
  }

  <article class="prose" id="article" style="margin-top:34px">
    <Content />
  </article>

  {images.length > 0 && <Reader title={f.data.title} pages={readerPages} jumpSelector=".prose img" />}

  <script is:inline>
    document.getElementById('btn-read')?.addEventListener('click', () => window.openReader(0));
    document.querySelectorAll('.thumb').forEach((th) => {
      th.addEventListener('click', () => window.openReader(Number(th.dataset.page)));
    });

    /* 分享貼文：點擊才載入 FB post plugin（iframe 內含分享目標的圖文） */
    document.getElementById('btn-embed')?.addEventListener('click', () => {
      const box = document.getElementById('fb-embed');
      const iframe = document.createElement('iframe');
      iframe.src = box.dataset.src;
      iframe.style.cssText = 'width:500px;max-width:100%;height:660px;border:0;background:#fff;border-radius:4px;';
      iframe.setAttribute('scrolling', 'auto');
      iframe.setAttribute('allow', 'encrypted-media; web-share');
      box.replaceChildren(iframe);
    });
  </script>
</Layout>
