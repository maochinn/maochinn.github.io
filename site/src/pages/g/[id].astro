---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Reader from '../../components/Reader.astro';
import type { Namespace } from '../../data/taxonomy';
import {
  getGalleries,
  getAllMetas,
  buildCounts,
  galleryMeta,
  nsUrl,
  fmt,
  fmtDate,
} from '../../lib/site';

export async function getStaticPaths() {
  const galleries = await getGalleries();
  return galleries.map((g) => ({ params: { id: String(g.data.id) }, props: { g } }));
}

const { g } = Astro.props;
const d = g.data;
const m = galleryMeta(g);
const masked = d.rating !== 'all';

const counts = buildCounts((await getAllMetas()).metas);
const cnt = (ns: Namespace, name: string) => {
  const c = counts.get(ns)?.get(name);
  return c ? c.galleries + c.posts : 0;
};
// 檔案卡列：namespace → 顯示名 + 值
const rows: { label: string; ns: Namespace; names: string[] }[] = [
  { label: '系列', ns: 'parody', names: m.parodies },
  { label: '角色', ns: 'character', names: m.characters },
  { label: '標籤', ns: 'tag', names: m.tags },
  { label: '作者', ns: 'artist', names: m.artists },
  { label: '社團', ns: 'group', names: m.groups },
  { label: '語言', ns: 'language', names: m.languages },
  { label: '分類', ns: 'category', names: m.categories },
].filter((r) => r.names.length > 0);

// 閱讀器用：原始大圖的 URL（依閱讀順序）
const pageSrcs = d.pages.map((p) => p.src);
---

<Layout title={d.title} description={d.alt || d.title}>
  <div class="detail" data-nsfw={masked ? d.rating : undefined} data-gid={d.id}>
    <div class="d-cover">
      <div class:list={['cover', { masked }]}>
        <Image class="coverart" src={d.cover} alt={d.alt || d.title} width={640} />
        {
          masked && (
            <div class="mask">
              <b>{d.rating.toUpperCase()}</b>
              <i>點擊確認顯示（含縮圖）</i>
            </div>
          )
        }
      </div>
    </div>
    <div class="d-info">
      <h1>{d.title}</h1>
      {d.alt && <p class="alt">{d.alt}</p>}
      <div class="gid">#{d.id}</div>
      <div class="meta">
        {
          rows.map((r) => (
            <div class="mrow">
              <span>{r.label}</span>
              <div class="chips">
                {r.names.map((name) => (
                  <a class="chip" href={nsUrl(r.ns, name)}>
                    {name} <em>{cnt(r.ns, name)}</em>
                  </a>
                ))}
              </div>
            </div>
          ))
        }
        <div class="mrow">
          <span>頁數</span>
          <div class="chips"><span class="chip static">{d.pages.length} pages</span></div>
        </div>
        <div class="mrow">
          <span>上傳於</span>
          <div class="chips"><span class="chip static">{fmtDate(d.date)}</span></div>
        </div>
      </div>
      <div class="btns">
        <button class="btn pink" id="btn-read">▶ 開始閱讀</button>
        <button class="btn pink" id="btn-fav" data-fav={d.fav}>♥ 收藏 ({fmt(d.fav)})</button>
      </div>
    </div>
  </div>

  <div class="thumbs">
    {
      d.pages.map((p, i) => (
        <button class:list={['thumb', { masked }]} data-page={i} aria-label={`第 ${i + 1} 頁`}>
          <Image src={p} alt={`第 ${i + 1} 頁`} width={240} />
          <i>{i + 1}</i>
        </button>
      ))
    }
  </div>

  <Reader title={d.title} pages={pageSrcs.map((src) => ({ src }))} />

  <script is:inline>
    /* ---------- R15/R18 遮罩 ---------- */
    const detail = document.querySelector('.detail');
    const gid = detail?.dataset.gid;
    const nsfw = detail?.dataset.nsfw;
    const maskedEls = [...document.querySelectorAll('.masked')];
    const reveal = () => maskedEls.forEach((el) => el.classList.add('revealed'));
    let revealed = !nsfw;
    if (nsfw && sessionStorage.getItem('reveal-' + gid)) {
      revealed = true;
      reveal();
    }
    const confirmReveal = () => {
      if (revealed) return true;
      revealed = true;
      sessionStorage.setItem('reveal-' + gid, '1');
      reveal();
      return false; // 這一下點擊只做「顯示」，不觸發後續動作
    };
    document.querySelector('.d-cover .cover')?.addEventListener('click', confirmReveal);

    document.getElementById('btn-read')?.addEventListener('click', () => {
      if (confirmReveal()) window.openReader(0);
    });
    document.querySelectorAll('.thumb').forEach((th) => {
      th.addEventListener('click', () => {
        if (confirmReveal()) window.openReader(Number(th.dataset.page));
      });
    });

    /* ---------- 收藏（純本機趣味） ---------- */
    const favBtn = document.getElementById('btn-fav');
    favBtn?.addEventListener('click', () => {
      const n = Number(favBtn.dataset.fav) + 1;
      favBtn.dataset.fav = String(n);
      favBtn.textContent = `♥ 已收藏 (${n.toLocaleString('en-US')})`;
    });
  </script>
</Layout>
