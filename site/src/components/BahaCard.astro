---
import type { BahaPost } from '../lib/site';
import { bahaMeta } from '../lib/site';

interface Props {
  b: BahaPost;
}
const { b } = Astro.props;
const m = bahaMeta(b);
const cover = m.images?.[0]?.src;
---

<a class="g-card" href={m.url}>
  <div class="cover">
    {
      cover ? (
        <img class="coverart" src={cover} alt={b.data.title} loading="lazy" />
      ) : (
        <div class="text-cover">
          <span class="tc-title">{b.data.title}</span>
          <i class="tc-mark">STUDIO MAOCHINN · BAHA</i>
        </div>
      )
    }
    <span class:list={['badge', { pink: m.categories[0] === '創作' }]}>{m.categories[0]}</span>
    <span class="pages-badge">{m.pages > 0 ? `${m.pages}P` : `${m.minutes} min`}</span>
  </div>
  <div class="cap">📄 {b.data.title}</div>
</a>
